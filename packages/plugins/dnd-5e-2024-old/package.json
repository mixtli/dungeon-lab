{
  "name": "@dungeon-lab/plugin-dnd-5e-2024-old",
  "version": "0.1.0",
  "description": "D&D 5e (2024) Game System Plugin for Dungeon Lab",
  "author": "Mixtli Dorantes",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./web": {
      "import": "./dist/web/index.js",
      "types": "./dist/web/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "echo 'Legacy plugin - build disabled'",
    "check": "echo 'Legacy plugin - check disabled'",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "test": "vitest run",
    "import:classes": "tsx ./src/scripts/import-character-classes.ts",
    "import:species": "tsx ./src/scripts/import-species.ts",
    "import:backgrounds": "tsx ./src/scripts/import-backgrounds.ts",
    "import:items": "tsx ./src/scripts/import-items.ts",
    "import:monsters": "tsx ./src/scripts/import-monsters.ts",
    "import:spells": "tsx ./src/scripts/import-spells.ts",
    "import:feats": "tsx ./src/scripts/import-feats.ts",
    "import:characters": "tsx --inspect=9222 ./src/scripts/import-characters.ts",
    "import:maps": "tsx ./src/scripts/import-maps.ts",
    "import:campaigns": "tsx ./src/scripts/import-campaigns.ts",
    "import:all": "npm run import:classes && npm run import:species && npm run import:backgrounds && npm run import:items && npm run import:monsters && npm run import:spells && npm run import:feats && npm run import:characters && npm run import:maps && npm run import:campaigns"
  },
  "dependencies": {
    "@dungeon-lab/client": "file:../../client",
    "@dungeon-lab/shared": "file:../../shared",
    "flat": "^6.0.1",
    "handlebars-helpers": "^0.10.0",
    "node-fetch": "^3.3.2",
    "sprintf-js": "^1.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/handlebars": "^4.0.40",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.13.11",
    "typescript": "^5.8.2",
    "vitest": "^1.6.1"
  }
}
